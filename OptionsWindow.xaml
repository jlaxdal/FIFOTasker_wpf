<Window x:Class="FIFOTasker_wpf.OptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Options" Height="180" Width="420"
        WindowStyle="SingleBorderWindow" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="20">
        <CheckBox x:Name="chkAutoStart" Content="Start FIFOTasker when I log in" 
                  VerticalAlignment="Top" FontSize="14" Margin="0,10,0,0"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
            <Button Content="Save Changes" Width="110" Height="34" Margin="0,0,12,0"
                    Click="Save_Click" Background="#006400" Foreground="White"/>
            <Button Content="Cancel" Width="90" Height="34" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>