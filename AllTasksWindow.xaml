<Window x:Class="FIFOTasker_wpf.AllTasksWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="All Tasks" Height="520" Width="680"
        WindowStyle="SingleBorderWindow" ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="12">
        <ListView x:Name="lvAllTasks" SelectionMode="Single">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Summary" Width="320">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Summary}" 
                                           TextTrimming="CharacterEllipsis"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Added" Width="140" DisplayMemberBinding="{Binding Added, StringFormat='yyyy-MM-dd HH:mm'}"/>
                    <GridViewColumn Header="Finished" Width="140" DisplayMemberBinding="{Binding Finished, StringFormat='yyyy-MM-dd HH:mm'}"/>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</Window>